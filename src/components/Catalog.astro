---
import VehicleCard from "./VehicleCard.astro";
import a3sb from "../assets/a3sb.png";
import g8gtd from "../assets/g8gtd.png";
import mglb200 from "../assets/mglb200.png";
import imgpng from "../assets/imagee.png";
import rGS from "../assets/gs1300.png";
import panamera from "../assets/panamera.png";
---

<section id="catalogue" class="py-32 px-6 md:px-16 bg-void border-b border-line">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-20 fade-up">
      <div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-sand mb-4">Exemples de Sourcing</p>
        <h2 class="text-3xl md:text-5xl font-serif text-concrete">Nos véhicules sourçables.</h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <VehicleCard
        imageSrc={panamera}
        alt="Porsche 911"
        title="Porsche Panamera 4S Chrono"
        meta="2011 • 151 000 km"
        price="25 000 €"
        subtitle="Modèle sourçable sur demande"
      />
      <VehicleCard
        imageSrc={mglb200}
        alt="Mercedes GLB 200 AMG Line"
        title="Mercedes GLB 200 AMG Line"
        meta="2020 • 29 000 km"
        price="29 000 €"
        subtitle="Modèle sourçable sur demande"
        delayMs={100}
      />
      <VehicleCard
        imageSrc={g8gtd}
        alt="Volkswagen Golf 8 GTD"
        title="Volkswagen Golf 8 GTD"
        meta="2022 • 77 000 km"
        price="29 000 €"
        subtitle="Modèle sourçable sur demande"
        delayMs={200}
      />
      <VehicleCard
        imageSrc={a3sb}
        alt="Audi A3 Sportback S-Line"
        title="Audi A3 Sportback S-Line"
        meta="2024 • 28 000 km"
        subtitle="Modèle sourçable sur demande"
        delayMs={300}
      />
    </div>
  </div>
</section>

<section id="moto" class="py-32 px-6 md:px-16 bg-onyx border-b border-line">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-20 fade-up">
      <div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-sand mb-4">2 Roues Premium</p>
        <h2 class="text-3xl md:text-5xl font-serif text-concrete">Motos Allemandes.</h2>
        <p class="text-concrete/60 font-light text-sm mt-4 max-w-2xl">
          Nous proposons aussi des motos premium en arrivage, et du sourcing sur-mesure selon votre usage : route,
          sport-GT ou aventure.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <VehicleCard
        imageSrc="https://live.staticflickr.com/65535/52684830432_24579a09cc_b.jpg"
        alt="BMW S 1000 RR"
        badge="Sport"
        title="BMW S 1000 RR"
        meta="2021 • 18 000 km"
        subtitle="Disponible selon arrivage"
        titleClass="text-xl"
        metaClass="text-xs"
      />
      <VehicleCard
        imageSrc={rGS}
        alt="BMW 1300 GS"
        badge="Adventure"
        title="BMW 1300 GS"
        meta="2025 • neuve"
        subtitle="Disponible selon arrivage"
        titleClass="text-xl"
        metaClass="text-xs"
        delayMs={100}
      />
      <VehicleCard
        imageSrc={imgpng}
        alt="BMW R 18"
        badge="Cruiser"
        title="BMW R 18"
        meta="2023 • 8 000 km"
        subtitle="Sourçable sur demande"
        titleClass="text-xl"
        metaClass="text-xs"
        delayMs={200}
      />
    </div>

    <div class="mt-20 text-center fade-up">
      <a href="#dossier" class="inline-block border border-concrete/20 px-8 py-4 text-[10px] uppercase tracking-widest font-bold text-concrete hover:bg-concrete hover:text-void transition-colors">
        Rechercher une Moto Allemande
      </a>
    </div>
  </div>
</section>
